# ── Application ──────────────────────────────────────────────────
APP_ENV=production

# ── Database ──────────────────────────────────────────────────────
# SQLite (default, no extra setup needed):
DATABASE_URL=sqlite:////data/invest_ai.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/invest_ai

# ── AI (OpenAI GPT-4o) ────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Security ──────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# ── CORS ──────────────────────────────────────────────────────────
# In production, restrict to your actual domain:
# CORS_ORIGINS=["https://your-domain.com"]
CORS_ORIGINS=["*"]

# ── SMTP (email sending for registration) ─────────────────────────
# Required for self-registration: password is sent to new user's email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@your-domain.com
